{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-opus-4-6-latest",
  "small_model": "anthropic/claude-3-5-haiku-latest",
  "tools": {
    "cf-portal_gitlab-mcp-server_*emoji*": false,
    "cf-portal_gitlab-mcp-server_list_merge_request_discussions*": false,
    "cf-portal_gitlab-mcp-server_add*": false,
    "cf-portal_gitlab-mcp-server_update*": false
  },
  "mcp": {
    "excalidraw": {
      "type": "remote",
      "url": "https://mcp.excalidraw.cfdata.org/mcp",
      "enabled": false
    },
    "cf-portal": {
      "type": "remote",
      "url": "https://portal.mcp.cfdata.org/mcp?optimize_context=minimize_tools",
      "enabled": true
    },
    "context7": {
      "enabled": false
    },
    "sourcegraph": {
      "type": "local",
      "command": ["/Users/jevans/cloudflare/aberglund/srch-cli/srch", "--mcp"],
      "enabled": true
    }
  },
  "plugin": [
    "@franlol/opencode-md-table-formatter@0.0.3",
    "@mathew-cf/opencode-terminal-notifier@0.1.3"
  ],
  "lsp": {
    "rust": {
      "command": ["lspmux", "client", "--server-path", "rust-analyzer"],
      "extensions": [".rs"]
    },
    "gopls": {
      "command": ["lspmux", "client", "--server-path", "gopls"],
      "extensions": [".go"]
    }
  },
  "permission": {
    "doom_loop": "ask",
    "bash": {
      "*": "ask",
      "apm list *": "allow",
      "apm search *": "allow",
      "awk *": "allow",
      "basename *": "allow",
      "cargo build *": "allow",
      "cargo lint *": "allow",
      "cargo metadata *": "allow",
      "cargo nexttest *": "allow",
      "cargo test *": "allow",
      "cat *": "allow",
      "clickhouse-cli *": "allow",
      "cloudflared *": "allow",
      "cloudflared access *": "allow",
      "column *": "allow",
      "cut *": "allow",
      "curl -s *": "allow",
      "curl --silent *": "allow",
      "curl -sS *": "allow",
      "date": "allow",
      "date *": "allow",
      "df *": "allow",
      "diff *": "allow",
      "dig *": "allow",
      "dirname *": "allow",
      "docker *": "allow",
      "du *": "allow",
      "echo *": "allow",
      "env": "allow",
      "cargo test *": "allow",
      "fd *": "allow",
      "file *": "allow",
      "find *": "allow",
      "git blame *": "allow",
      "git branch": "allow",
      "git branch --contains *": "allow",
      "git branch --format *": "allow",
      "git branch --list": "allow",
      "git branch --list *": "allow",
      "git branch --show-current": "allow",
      "git branch -a": "allow",
      "git branch -l": "allow",
      "git branch -r": "allow",
      "git describe": "allow",
      "git describe *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git grep *": "allow",
      "git log": "allow",
      "git log *": "allow",
      "git ls-files": "allow",
      "git ls-files *": "allow",
      "git remote -v": "allow",
      "git remote show *": "allow",
      "git rev-parse *": "allow",
      "git show": "allow",
      "git show *": "allow",
      "git show-ref": "allow",
      "git show-ref *": "allow",
      "git status": "allow",
      "git status *": "allow",
      "git tag": "allow",
      "git tag --contains *": "allow",
      "git tag --list": "allow",
      "git tag --list *": "allow",
      "git tag -l": "allow",
      "git worktree *": "allow",
      "glab *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "ls": "allow",
      "ls *": "allow",
      "printf *": "allow",
      "ps *": "allow",
      "pwd": "allow",
      "rg *": "allow",
      "sed *": "allow",
      "sed --in-place": "ask",
      "sed --in-place *": "ask",
      "sed -i": "ask",
      "sed -i *": "ask",
      "sort *": "allow",
      "source *": "allow",
      "stat *": "allow",
      "strings *": "allow",
      "tail *": "allow",
      "test": "allow",
      "test *": "allow",
      "tr *": "allow",
      "uniq *": "allow",
      "wc *": "allow",
      "which *": "allow",
      "whoami": "allow",
      "wrangler tail *": "allow",
      "wrangler whoami": "allow",
      "wrangler d1 list *": "allow",
      "wrangler d1 info *": "allow",
      "wrangler kv key list *": "allow",
      "wrangler kv key get *": "allow",
      "wrangler kv namespace list *": "allow",
      "wrangler r2 bucket list *": "allow",
      "wrangler r2 object get *": "allow",
      "wrangler secret list *": "allow",
      "wrangler versions list *": "allow",
      "wrangler versions view *": "allow",
      "wrangler deployments list *": "allow",
      "wrangler deployments view *": "allow",
      "wrangler pages list *": "allow"
    },
    "external_directory": {
      "~/cloudflare/**": "allow",
      "~/.cargo/**": "allow",
      "~/.config/opencode/skills/**": "allow"
    },
    "webfetch": "allow",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    }
  }
}
