-- ~/.config/hammerspoon/locations.private.lua.example
-- Copy this file to locations.private.lua and customize your paths
-- The private file is ignored by git and won't be checked in

-- Return a table with your custom locations
-- Format: key = { "session-name", "/absolute/path" }
-- Only include locations you want to override from defaults

return {
	-- Example: override dotfiles location
	dotfiles = { "dotfiles", "/Users/YOUR_USERNAME/dotfiles" },
	
	-- Example: override work locations
	-- opencode = { "opencode", "/Users/YOUR_USERNAME/work/opencode" },
	-- scratch = { "scratch", "/Users/YOUR_USERNAME/work/scratch" },
	
	-- Add new custom locations
	-- myproject = { "myproject", "/Users/YOUR_USERNAME/projects/myproject" },
}
